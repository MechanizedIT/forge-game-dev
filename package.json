{
  "name": "forge-game-dev",
  "version": "0.0.0",
  "private": true,
  "description": "Build Week prototype for a quest-driven Codex game-development companion.",
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "typecheck": "tsc --noEmit && tsc -p tsconfig.dashboard.json --noEmit",
    "test": "tsx --test tests/contracts.test.ts tests/prepared-quest.test.ts tests/quest-runner.test.ts tests/quest-completion.test.ts tests/workspace.test.ts tests/godot-executable.test.ts tests/godot-bootstrap.test.ts",
    "check": "npm run typecheck && npm test",
    "dashboard:dev": "vite",
    "dashboard:build": "vite build",
    "dashboard:preview": "vite preview",
    "demo:prepare": "tsx src/demo/cli.ts prepare",
    "demo:reset": "tsx src/demo/cli.ts reset",
    "demo:play": "tsx src/demo/cli.ts play",
    "quest:run": "tsx src/quest-runner/cli.ts",
    "godot:bootstrap": "tsx src/godot/bootstrap-cli.ts",
    "godot:verify": "tsx src/godot/verify-fixture.ts"
  },
  "dependencies": {
    "@openai/codex-sdk": "0.144.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "yauzl": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@types/yauzl": "^3.4.0",
    "@types/yazl": "^3.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "yazl": "^3.3.1"
  }
}
