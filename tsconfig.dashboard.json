{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/dashboard/**/*.ts",
    "src/dashboard/**/*.tsx",
    "src/dashboard-v2/**/*.ts",
    "src/dashboard-v2/**/*.tsx",
    "vite.config.ts"
  ]
}
